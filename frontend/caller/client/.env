VITE_CALLER_NUMBER=+91 90000 00001
VITE_RECEIVER_NUMBER=+91 98765 43210
# VITE_API_BASE_URL intentionally unset — api/client.js falls back to
# `${window.location.hostname}:5005`, so the app reaches the backend at
# whatever host/IP the browser used to load this page (works for both
# localhost and phones on the same LAN).

# TURN server for WebRTC (Metered.ca account credentials, used client-side
# to fetch short-lived TURN username/password pairs) — required once caller
# and receiver are on separate public networks instead of the same LAN,
# since STUN alone can't traverse symmetric/carrier-grade NAT.
# Real values go in .env.local (gitignored), NOT here — this file is
# committed to the repo. See .env.local.example for the two vars needed:
#   VITE_TURN_DOMAIN, VITE_TURN_API_KEY
